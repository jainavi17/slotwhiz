# Local Docker Postgres default
DATABASE_URL="postgresql://slotwhiz:slotwhiz@postgres:5432/slotwhiz?schema=public"

# Replace with CockroachDB URL when ready (example):
# DATABASE_URL="postgresql://<user>:<password>@<cockroach-host>:26257/slotwhiz?sslmode=require"

REDIS_URL="redis://redis:6379"
NEXT_PUBLIC_APP_NAME="SlotWhiz"

# Local development only (set in .env)
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Production: set AUTH_SECRET in Render env vars (use a different value than local)
